  "cssVarsTemplate": "@tailwind base;\n@tailwind components;\n@tailwind utilities;\n\n@layer base {\n  :root {\n    --background: #fbfbfa;\n    --foreground: #141414;\n    --card: #ffffff;\n    --card-foreground: #141414;\n    --popover: #ffffff;\n    --popover-foreground: #141414;\n    --primary: #0169cc;\n    --primary-foreground: #fcfcfc;\n    --secondary: #f0f0ef;\n    --secondary-foreground: #1f1f1f;\n    --muted: #f2f2f1;\n    --muted-foreground: #6d6d6d;\n    --accent: #ebf4ff;\n    --accent-foreground: #0f1720;\n    --destructive: oklch(0.577 0.245 27.325);\n    --border: #dededb;\n    --input: #d7d7d4;\n    --ring: #0169cc;\n    --chart-1: #87c6ff;\n    --chart-2: #2688df;\n    --chart-3: #0169cc;\n    --chart-4: #0052a3;\n    --chart-5: #123a63;\n    --radius: 0.875rem;\n  }\n\n  .dark {\n    --background: #111111;\n    --foreground: #fcfcfc;\n    --card: #181818;\n    --card-foreground: #fcfcfc;\n    --popover: #242424;\n    --popover-foreground: #f6f6f6;\n    --primary: #0169cc;\n    --primary-foreground: #fcfcfc;\n    --secondary: #222222;\n    --secondary-foreground: #f5f5f5;\n    --muted: #1c1c1c;\n    --muted-foreground: #a7a7a7;\n    --accent: #343434;\n    --accent-foreground: #fcfcfc;\n    --destructive: oklch(0.704 0.191 22.216);\n    --border: #303030;\n    --input: #2c2c2c;\n    --ring: #0169cc;\n    --chart-1: #5ab5ff;\n    --chart-2: #1685e5;\n    --chart-3: #0169cc;\n    --chart-4: #0d4f91;\n    --chart-5: #123a63;\n  }\n}\n\n@layer base {\n  * {\n    @apply border-border;\n  }\n  body {\n    @apply bg-background text-foreground;\n  }\n}"
